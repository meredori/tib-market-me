{
  "name": "tibia-market-tooling",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -k -n BE,FE -c green,cyan \"npm run dev:be\" \"npm run dev:fe\"",
    "dev:inspect": "concurrently -k -n BE,FE -c green,cyan \"npm run dev:be\" \"npm --prefix ui-app run dev -- --host 127.0.0.1 --port 5173\"",
    "dev:be": "npm --prefix server run dev",
    "build:be": "npm --prefix server run build",
    "sync:be": "npm --prefix server run sync",
    "migrate:be": "npm --prefix server run migrate",
    "dev:fe": "npm --prefix ui-app run dev",
    "build:fe": "npm --prefix ui-app run build",
    "preview:fe": "npm --prefix ui-app run preview",
    "preview:inspect": "npm --prefix ui-app run preview -- --host 127.0.0.1 --port 4173",
    "generate:items": "node ./scripts/tibia-assets-generate.cjs -p ./assets/appearances.dat -c ./assets/catalog-content.json -m items -o ./assets/generated/items-archive",
    "stage:items": "npm --prefix server run stage:items",
    "prebuild": "npm run generate:items && npm run stage:items"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "@playwright/test": "^1.61.0",
    "tibia-assets": "^1.3.3"
  }
}
