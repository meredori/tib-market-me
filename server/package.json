{
  "name": "tibia-market-server",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts serve",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "start": "node dist/index.js serve",
    "sync": "tsx src/index.ts sync",
    "sync:public": "tsx src/index.ts sync-public",
    "enrich:public": "tsx src/index.ts enrich-public",
    "reset:public": "tsx src/index.ts reset-public",
    "migrate": "tsx src/index.ts migrate",
    "stage:items": "tsx src/tools/stagePublicItems.ts"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "better-sqlite3": "^11.8.1",
    "fastify": "^5.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.30",
    "tsx": "^4.20.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
